      },
      "RouteRequest": {
        "description": "Body for POST /api/route \u2014 two human-readable addresses inside DFW.\n\nThe geocoder runs server-side, so the API consumer doesn't need to know\ncoordinates. `alpha` (the cleanest-route tuning knob in\nconfig.ROUTE_PM_ALPHA) is intentionally not exposed here \u2014 it's an\ninternal weighting parameter, not a user-facing input.",
        "properties": {
          "end": {
            "description": "End address (street, landmark, or neighborhood).",
            "minLength": 1,
            "title": "End",
            "type": "string"
          },
          "start": {
            "description": "Start address (street, landmark, or neighborhood).",
            "minLength": 1,
            "title": "Start",
            "type": "string"
          }
        },
        "required": [
          "start",
          "end"
        ],
        "title": "RouteRequest",
        "type": "object"
      },
      "RouteResponse": {
        "properties": {
          "cleanest": {
            "$ref": "#/components/schemas/RouteStats"
          },
          "shortest": {
            "$ref": "#/components/schemas/RouteStats"
          },
          "timestamp": {
            "description": "PipelineSnapshot timestamp the route was computed against",
            "title": "Timestamp",
            "type": "string"
          }
        },
        "required": [
          "cleanest",
          "shortest",
          "timestamp"
        ],
        "title": "RouteResponse",
        "type": "object"
      },
      "RouteStats": {
        "properties": {
