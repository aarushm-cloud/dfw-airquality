            "type": "number"
          },
          "total_exposure": {
            "description": "\u03a3 pm_midpoint \u00d7 edge_length (\u00b5g/m\u00b3\u00b7m)",
            "title": "Total Exposure",
            "type": "number"
          },
          "walk_seconds": {
            "description": "Walk time at 1.4 m/s",
            "title": "Walk Seconds",
            "type": "number"
          }
        },
        "required": [
          "geometry",
          "distance_m",
          "mean_pm25",
          "walk_seconds",
          "total_exposure"
        ],
        "title": "RouteStats",
        "type": "object"
