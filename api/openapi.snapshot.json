  "info": {
    "description": "JSON wrapper around the DFW air quality pipeline (PurpleAir + OpenAQ + IDW + traffic/wind adjustment).",
    "title": "AERIA \u00b7 DFW Air Quality API",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/": {
      "get": {
        "operationId": "root__get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": true,
                  "title": "Response Root  Get",
                  "type": "object"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Root",
        "tags": [
          "meta"
        ]
      }
    },
    "/api/cells/at": {
      "get": {
        "description": "Reverse-geocode a coordinate to its zip + neighborhood + grid cell.\n\nUsed by the frontend after a cell click, since the click only knows row/col\nand needs a zip for display. Cached with 2-decimal rounding (~1.1 km).",
        "operationId": "get_cell_at_api_cells_at_get",
        "parameters": [
          {
            "in": "query",
            "name": "lat",
            "required": true,
            "schema": {
              "title": "Lat",
              "type": "number"
            }
          },
          {
            "in": "query",
            "name": "lon",
            "required": true,
            "schema": {
              "title": "Lon",
              "type": "number"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CellAtResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Get Cell At",
        "tags": [
          "cells"
        ]
      }
    },
    "/api/cells/{zip_code}": {
      "get": {
        "description": "Look up the nearest grid cell for a US zip code and return its PM2.5.\n\nUses the same cached pipeline snapshot as /api/grid, so calls are fast\nonce the grid is warm.",
        "operationId": "get_cell_api_cells__zip_code__get",
        "parameters": [
          {
            "in": "path",
            "name": "zip_code",
            "required": true,
            "schema": {
              "title": "Zip Code",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CellResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Get Cell",
        "tags": [
          "cells"
        ]
      }
    },
    "/api/geocode/suggest": {
      "get": {
        "operationId": "suggest_api_geocode_suggest_get",
        "parameters": [
          {
            "description": "Partial address text",
            "in": "query",
            "name": "q",
            "required": true,
            "schema": {
              "description": "Partial address text",
              "minLength": 2,
              "title": "Q",
              "type": "string"
            }
          },
          {
            "description": "Max suggestions",
            "in": "query",
            "name": "limit",
            "required": false,
            "schema": {
              "default": 5,
              "description": "Max suggestions",
              "maximum": 10,
              "minimum": 1,
              "title": "Limit",
              "type": "integer"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/GeocodeSuggestion"
                  },
                  "title": "Response Suggest Api Geocode Suggest Get",
                  "type": "array"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Suggest",
        "tags": [
          "geocode"
        ]
      }
    },
    "/api/grid": {
      "get": {
        "description": "Full IDW + traffic/wind-adjusted PM2.5 grid over the Dallas bounding box.\n\nSlow on first call (~5-15s end-to-end including all upstream fetches);\ncached for 5 minutes after that.",
        "operationId": "get_grid_api_grid_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GridResponse"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Get Grid",
        "tags": [
          "grid"
        ]
      }
    },
    "/api/health": {
      "get": {
        "description": "Cheap liveness + cache-warm probe for the frontend.\n\nHit on every page load \u2014 must stay fast (no pipeline calls, no I/O).",
        "operationId": "health_api_health_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": true,
                  "title": "Response Health Api Health Get",
                  "type": "object"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Health",
        "tags": [
          "meta"
        ]
      }
    },
    "/api/route": {
      "post": {
        "description": "Compare a length-only shortest path against a PM-weighted cleanest\npath between two DFW addresses. Both addresses are geocoded server-side\nvia LocationIQ and snapped to the nearest node on the OSM walking graph.\n\nFirst call after a cold boot pays the OSMnx walking-graph load (set\nAERIA_PRELOAD_GRAPH=1 to amortize that at startup). Subsequent calls\nride the in-process graph + 5-min grid cache and respond in <1s.",
        "operationId": "post_route_api_route_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RouteRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RouteResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Post Route",
        "tags": [
          "route"
        ]
      }
    },
    "/api/sensors": {
      "get": {
        "description": "Live PM2.5 readings from PurpleAir + OpenAQ inside the Dallas bounding box.\n\nPurpleAir values are EPA-corrected at ingest. OpenAQ values are\nreference-grade and reported as-is. Cached for 5 minutes.",
        "operationId": "get_sensors_api_sensors_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SensorsResponse"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "summary": "Get Sensors",
        "tags": [
          "sensors"
        ]
      }
    }
  }
}
