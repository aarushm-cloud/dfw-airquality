# DFW Air Quality — backend environment variables.
# Copy this file to .env at the repo root and fill in real keys.
# .env is gitignored; this template is the documented set of secrets.

# PurpleAir live PM2.5 sensors (Phase 1+).
PURPLEAIR_API_KEY=your_key_here

# OpenAQ secondary PM2.5 source (Phase 1+).
OPENAQ_API_KEY=your_key_here

# OpenWeatherMap live wind (Phase 3+).
OPENWEATHERMAP_API_KEY=your_key_here

# TomTom Traffic live congestion (Phase 3+).
TOMTOM_API_KEY=your_key_here

# LocationIQ forward geocoding for the Phase 5 route comparator
# (engine/router.py). Free tier: 5,000 requests/day. Sign up (no card
# required) at https://locationiq.com/register.
LOCATIONIQ_API_KEY=your_key_here
